# 应用
app:
  env: dev # dev|testing|production dev=本地环境 testing=测试环境 production=生产环境
  cli-version: v2.0.0
  name: gin
  mode: debug # debug|test|release debug=本地环境 test=测试环境 release=生产环境
  port: 8080
  timezone: Asia/Shanghai
  proxies: 127.0.0.1/8080 # 代理地址多个地址用逗号分隔
  timeout: 10s # 请求超时时间(time.Duration单位:秒)

# 数据库
databases:
  default: mysql # 默认数据库
  # 慢查询的时间,超过这个时间会记录到日志中
  slow-query-duration: 3s # 3秒(time.Duration)
  # Mysql数据库
  mysql:
    driver: mysql
    # host: "username:password@tcp(127.0.0.1:3306)/databaseName?charset=utf8mb4&parseTime=True&loc=Asia%2FShanghai"
    host: 127.0.0.1
    port: 3306
    username: root
    password: root
    database: gin

  # Postgresql数据库
  pgsql:
    driver: pgsql
    host: 127.0.0.1
    port: 5432
    username: testuser
    password: 123456
    database: testdb
    ssl-mode: disable

  # sqlite数据库
  sqlite:
    driver: sqlite
    path: E:/sqlite/gin.db

  # sqlsrv数据库
  sqlsrv:
    driver: sqlsrv
    host: 127.0.0.1
    port: 1433
    username: sa
    password: Aa123456
    database: gin

# 缓存
cache:
  driver: "memory"  # memory|disk|redis # 为空默认内存缓存
  # Redis数据库
  redis:
    host: 127.0.0.1
    port: 6379
    db: 0
  # 内存缓存
  memory:
    default-expire: 5m # 默认过期时间(time.Duration)
    cleanup-interval: 10m # 清理数据的间隔时间(time.Duration)
  # 磁盘缓存
  disk:
    path: "storage/cache" # 缓存文件存放路径

# 跨域
cors:
  enabled: true # 是否开启跨域
  mode: "allow-all" # allow-all|whitelist # 跨域模式 allow-all: 允许所有域名访问 whitelist: 白名单模式
  allow-all:
    allow-origin: "*" # 允许访问的域名列表
    allow-headers: "*" # 允许的请求头列表
    expose-headers: "*" # 允许返回的响应头列表
    allow-methods: GET, POST, PUT, DELETE, OPTIONS # 允许的请求方法列表
    allow-credentials: "true" # 是否允许发送cookie
  whitelist:
    - allow-origin: http://127.0.0.1:8080 # 允许访问的域名列表
      allow-headers: Content-Type, AccessToken, Authorization, Token # 允许的请求头列表
      expose-headers: Content-Length, Access-Control-Allow-Origin, Access-Control-Allow-Headers, Content-Type # 允许返回的响应头列表
      allow-methods: GET, POST, PUT, DELETE, OPTIONS # 允许的请求方法列表
      allow-credentials: "true" # 是否允许发送cookie
    - allow-origin: example2.com # 允许访问的域名列表
      allow-headers: Content-Type, AccessToken, Authorization, Token # 允许的请求头列表
      expose-headers: Content-Length, Access-Control-Allow-Origin, Access-Control-Allow-Headers, Content-Type # 允许返回的响应头列表
      allow-methods: GET, POST, PUT, DELETE, OPTIONS # 允许的请求方法列表
      allow-credentials: "true" # 是否允许发送cookie

# Jwt
jwt:
  key: 123456789!@# # 加解密秘钥key
  exp: 7200 # 过期时间(单位秒) 2*60*60
  refresh-exp: 172800  # 刷新过期时间(单位秒) 2*24*60*60

# 日志配置
log:
  access: true # 是否记录访问日志
  max-size: 10 # 单个日志文件大小（MB）
  max-backups: 3  # 最多保留的旧日志文件数
  max-day: 28 # 保留的最大天数
  level: debug # 日志级别 debug|info|warn|error|dPanic|panic|fatal

# 翻译配置
i18n:
  dir: "storage/locales" # 翻译文件存放路径
  lang: "zh,en" # 默认语言,多个语言用逗号分隔

kafka:
  enabled: false # 是否启用kafka
  brokers:
    - "172.30.117.79:9092"

rabbitmq:
  enabled: false # 是否启用rabbitmq
  url: "amqp://admin:admin@172.30.117.79:5672/"